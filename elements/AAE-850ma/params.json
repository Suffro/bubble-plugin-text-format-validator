{
    "add_is_visible": true,
    "can_fit_height": true,
    "can_fit_width": true,
    "category": "visual elements",
    "default_dim": {
        "height": 50,
        "width": 50
    },
    "display": "Text format validator",
    "events": {
        "AAK": {
            "caption": "Format validation complete",
            "name": "validation_complete"
        },
        "AAL": {
            "caption": "Format validation passed",
            "name": "validation_passed"
        },
        "AAM": {
            "caption": "Format validation failed",
            "name": "validation_failed"
        }
    },
    "icon": "ion-android-done",
    "platform_type": "web",
    "property_applications": {
        "MinWidth": true,
        "resizable": true
    },
    "states": {
        "AAG": {
            "caption": "is valid",
            "initialization_code": {
                "fn": "function(properties, context) {\n\n\n\n}"
            },
            "name": "is_valid",
            "value": "text"
        },
        "AAH": {
            "caption": "error message",
            "doc": "If the format is valid, this will be empty",
            "initialization_code": {
                "fn": "function(properties, context) {\n\n\n\n}"
            },
            "name": "error_message",
            "value": "text"
        },
        "AAI": {
            "caption": "validated text",
            "initialization_code": {
                "fn": "function(properties, context) {\n\n\n\n}"
            },
            "name": "validated_value",
            "value": "text"
        },
        "AAJ": {
            "caption": "validated format",
            "initialization_code": {
                "fn": "function(properties, context) {\n\n\n\n}"
            },
            "name": "validation_type",
            "value": "text"
        }
    }
}